      "index": "bDGzzzl",
      "roundness": null,
      "seed": 389734274,
      "version": 505,
      "versionNonce": 657378526,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1768923085874,
      "link": null,
      "locked": false,
      "text": "Ingest Service API:\n\n- POST /transcription \nUpload a audio to process. Returns a job_id\n- GET /transcription/<job_id>\nGet the specific job\n- GET /transcription/<job_id>/result\nRetrieve transcript of a job\n- GET /transcription\nRetrieve every transcription job\n",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Ingest Service API:\n\n- POST /transcription \nUpload a audio to process. Returns a job_id\n- GET /transcription/<job_id>\nGet the specific job\n- GET /transcription/<job_id>/result\nRetrieve transcript of a job\n- GET /transcription\nRetrieve every transcription job\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
